{
  "plugins": [
    {
      "type": "Dockerfile",
      "src": "Dockerfile",
      "name": "odoo"
    },
    {
      "type": "plugin",
      "src": "postgresql",
      "name": "postgres",
      "version": "latest",
      "environment": {
        "POSTGRES_DB": "postgres",
        "POSTGRES_USER": "odoo",
        "POSTGRES_PASSWORD": "${POSTGRES_PASSWORD}"
      }
    }
  ],
  "env": {
    "POSTGRES_PASSWORD": "${POSTGRES_PASSWORD}" ,
    "ODOO_PASSWORD": "${ODOO_PASSWORD}"
  },
  "build": {
    "command": "docker build -t odoo-app .",
    "output": "dockerfile"
  },
  "start": {
    "command": "docker run -p $PORT:8069 -e HOST=$PGHOST -e USER=$PGUSER -e PASSWORD=$PGPASSWORD -e PORT=$PORT odoo-app"
  }
}
